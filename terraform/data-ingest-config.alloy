local.file_match "java_app_logs" {
  path_targets = [{"__address__" = "localhost", "__path__" = "/mnt/shared-logs/*.log", "service_name" = "data-ingest-service"}]
}

loki.source.file "ingest_logs" {
  targets    = local.file_match.java_app_logs.targets
  forward_to = [loki.write.loki_service.receiver]
}

loki.write "loki_service" {
  endpoint {
    url = "http://app-loki-service:80/loki/api/v1/push"
  }
}